{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PredictiveInsightResult",
  "type": "OBJECT",
  "properties": {
    "predictedBottleneck": {
      "type": "STRING",
      "description": "Identified ward or category response delay issues"
    },
    "estimatedTimeframeDays": {
      "type": "NUMBER",
      "description": "Estimated average resolution time in days"
    },
    "reliabilityRating": {
      "type": "NUMBER",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Reliability of the prediction score"
    },
    "actionableRecommendations": {
      "type": "ARRAY",
      "items": {
        "type": "STRING"
      },
      "description": "Suggested resource redistributions or alerts"
    }
  },
  "required": ["predictedBottleneck", "estimatedTimeframeDays", "reliabilityRating", "actionableRecommendations"]
}
